# Slash API Environment Variables
PORT=3000

# Telnyx (Voice)
TELNYX_API_KEY=your_telnyx_api_key_here
TELNYX_PHONE_NUMBER=+15551234567
TELNYX_CONNECTION_ID=your_connection_id_here
TELNYX_WEBHOOK_URL=https://your-deployment-url.com/api/webhooks/telnyx
TELNYX_WEBHOOK_VERIFY=false
# Option A: shared secret verification (simplest for hackathon wiring)
TELNYX_WEBHOOK_SECRET=
# Option B: Ed25519 verification (set public key from Telnyx portal)
TELNYX_WEBHOOK_PUBLIC_KEY=

# Tavily (Research)
TAVILY_API_KEY=your_tavily_api_key_here

# Yutori (Deep Research + Browsing)
YUTORI_API_KEY=your_yutori_api_key_here

# Modulate (event-day integration)
MODULATE_API_KEY=

# OpenAI (AI Negotiation)
OPENAI_API_KEY=your_openai_api_key_here

# Demo user phone (for local testing - calls route here instead of retention dept)
USER_PHONE_NUMBER=+15551234567

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
